# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://habeshahub:password@localhost:5432/habeshahub_db

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRES_IN=24h

# OpenAI
OPENAI_API_KEY=sk-your_openai_api_key_here

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_KEY=your_meilisearch_master_key

# CORS
CORS_ORIGINS=http://localhost:3001,http://localhost:19006

# Rate Limiting
RATE_LIMIT_POINTS=200
RATE_LIMIT_DURATION=86400

# Phase 3 — Infrastructure
# NATS Event Bus
NATS_URL=nats://localhost:4222
NATS_ENABLED=false

# S3 / Object Storage
S3_BUCKET=habeshahub-media
S3_REGION=us-west-2
S3_ACCESS_KEY=
S3_SECRET_KEY=
CDN_BASE_URL=https://cdn.habeshahub.com

# Firebase Cloud Messaging
FCM_PROJECT_ID=your_firebase_project_id
FCM_SERVER_KEY=your_fcm_server_key

# Apple Push Notification Service
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=com.habeshahub.app

# Analytics
CLICKHOUSE_URL=
POSTHOG_API_KEY=
